{
  "expo": {
    "name": "Sprout",
    "slug": "sprout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Sprout uses speech recognition to transcribe your voice notes into text.",
        "NSMicrophoneUsageDescription": "Sprout needs microphone access to record voice notes."
      },
      "bundleIdentifier": "com.anonymous.sprout"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.sprout"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-speech-recognition"
    ],
    "extra": {
      "eas": {
        "projectId": "f864b777-6af4-43a5-98f1-8aefab4f52aa"
      }
    }
  }
}
