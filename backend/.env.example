# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net

# Database name (use sprout_dev locally, sprout_prod in Railway)
DATABASE_NAME=sprout_dev

# JWT Secret - use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# SendGrid email delivery
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@sprout.app

# Frontend URL (used for activation email links)
FRONTEND_URL=http://localhost:5173

# Dev email whitelist (comma-separated, Gmail dots/+suffix are normalized)
EMAIL_WHITELIST_ENABLED=true
EMAIL_WHITELIST=csjingtao@gmail.com
